/**
 * Config.gs
 * ------------------------------------------------------------------
 * このファイルだけ編集すれば、コード本体（Code.gs など）を
 * 触らずに挙動を変えられるよう設定値を集約しています。
 *
 * ■ 機密情報（Slack の Webhook URL）について
 *   コードに直接書くと GitHub などに公開したとき漏れるため、
 *   スクリプトプロパティ（保管庫）に入れる方式にしています。
 *   設定方法は README.md の「初期設定」を参照してください。
 * ------------------------------------------------------------------
 */

const CONFIG = {
  // ── シート名 ─────────────────────────────────────────────
  // フォーム回答が自動で溜まるシート名（通常は「フォームの回答 1」）
  RESPONSE_SHEET_NAME: 'フォームの回答 1',
  // 整形後の管理台帳シート名（無ければ自動作成します）
  MANAGEMENT_SHEET_NAME: '問い合わせ管理',

  // ── 受付番号 ─────────────────────────────────────────────
  // 自動採番される受付番号の接頭辞（例: REQ-20260614-001）
  TICKET_PREFIX: 'REQ',

  // ── 自動返信メール（申込者・問い合わせ者あて）──────────────
  AUTO_REPLY: {
    ENABLED: true,
    // 件名。{{ticket}} は受付番号に置き換わります
    SUBJECT: '【受付完了】お問い合わせありがとうございます（{{ticket}}）',
    // 本文。{{name}} {{ticket}} が置き換わります
    BODY: [
      '{{name}} 様',
      '',
      'この度はお問い合わせいただきありがとうございます。',
      '以下の受付番号で承りました。',
      '',
      '　受付番号：{{ticket}}',
      '',
      '担当者より追ってご連絡いたします。',
      '今しばらくお待ちくださいませ。',
      '',
      '──────────────────',
      '株式会社サンプル / お問い合わせ窓口',
      'TEL: 00-0000-0000',
      '──────────────────',
    ].join('\n'),
    // 差出人の表示名（任意）
    SENDER_NAME: 'サンプル お問い合わせ窓口',
  },

  // ── 社内向けSlack通知 ────────────────────────────────────
  SLACK: {
    ENABLED: true,
    // 通知の見出し
    TITLE: ':inbox_tray: 新しい問い合わせが届きました',
  },

  // ── 社内向けメール通知（Slackを使わない場合の代替）──────────
  STAFF_EMAIL: {
    ENABLED: false,
    // 通知先（カンマ区切りで複数可）
    TO: 'staff@example.com',
    SUBJECT: '【新規問い合わせ】{{ticket}}',
  },

  // ── 列マッピング ─────────────────────────────────────────
  // フォームの質問文と、台帳の項目の対応。
  // 「フォームの質問のタイトル」を実際のフォームに合わせて変更してください。
  COLUMNS: {
    NAME: 'お名前',          // 申込者名に使う質問タイトル
    EMAIL: 'メールアドレス',  // 自動返信の宛先に使う質問タイトル
    CATEGORY: 'ご相談内容',   // 集計の分類に使う質問タイトル（任意）
  },

  // ── エラー時の通知先 ─────────────────────────────────────
  // 処理が失敗したとき管理者に知らせるメールアドレス
  ADMIN_EMAIL: Session.getActiveUser().getEmail(),
};

/**
 * スクリプトプロパティから Slack Webhook URL を取得します。
 * （README の手順で SLACK_WEBHOOK_URL を登録しておく）
 */
function getSlackWebhookUrl_() {
  return PropertiesService.getScriptProperties().getProperty('SLACK_WEBHOOK_URL');
}
